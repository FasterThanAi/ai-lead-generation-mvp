APP_NAME=AI Lead Generation MVP
APP_ENV=development
FRONTEND_URL=http://localhost:5173
DATABASE_URL=sqlite:///./leadgen.db
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIMENSION=3072
ENABLE_SEMANTIC_RAG=true
SEMANTIC_RAG_TOP_K=5
SEMANTIC_RAG_MIN_SCORE=0.60
GMAIL_CLIENT_ID=your_google_oauth_client_id
GMAIL_CLIENT_SECRET=your_google_oauth_client_secret
GMAIL_REDIRECT_URI=http://localhost:8000/api/gmail/oauth/callback
GMAIL_SENDER_EMAIL=your_email@gmail.com
GMAIL_DAILY_LIMIT=20
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000

# For production/Supabase, use:
# APP_ENV=production
# FRONTEND_URL=https://your-frontend-url.vercel.app
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@YOUR_SUPABASE_HOST:5432/postgres
# GMAIL_REDIRECT_URI=https://your-render-backend-url.onrender.com/api/gmail/oauth/callback
# BACKEND_HOST=0.0.0.0
# BACKEND_PORT=8000
